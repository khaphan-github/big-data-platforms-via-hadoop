# Transform Job Configuration

## HDFS Paths
HDFS_INPUT_PATH="hdfs://namenode:9000/data/articles"
HDFS_OUTPUT_PATH="hdfs://namenode:9000/work_zone/table_trending_words"

## Spark Configuration
SPARK_MASTER="yarn"
EXECUTOR_MEMORY="2G"
EXECUTOR_CORES="2"
DRIVER_MEMORY="2G"

## Processing Options
MIN_KEYWORD_LENGTH=2
REMOVE_STOPWORDS=true
OUTPUT_FORMAT="parquet"  # parquet, csv, or both

## Data Schema
# Input fields expected: publish_date, source, category, title, content
# Output fields: ngay (yyyyMMdd), nguon, chu_de, tu_khoa, so_lan_xuat_hien
